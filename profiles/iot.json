    "name": "iot",
    "description": "IoT / Home Assistant (container-first per Default)."
  },
  "requirements": {
    "adminRequired": true
  },
  "packages": [
    "docker-desktop"
  ],
  "actions": [],
  "services": {
    "database": { "mode": "Skip", "composeFile": "compose/db.compose.yaml" },
