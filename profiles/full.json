{
  "metadata": {
    "name": "full",
    "description": "Kuratiertes Full-Setup (dev + server + security + backup + docs + Container-Services)."
  },
  "requirements": {
    "adminRequired": true
  },
  "packages": [
    "git",
    "vscode",
    "nodejs-lts",
    "python-3",
    "dotnet-sdk-8",
    "docker-desktop",
    "windows-terminal",
    "github-cli",
    "putty",
    "winscp",
    "kubectl",
    "terraform",
    "azure-cli",
    "zap",
    "nmap",
    "wireshark",
    "7zip",
    "freefilesync",
    "aomei-backupper",
    "obsidian",
    "drawio",
    "sharex",
    "obs-studio"
  ],
  "actions": [
    { "id": "folders.dev", "options": {} },
    { "id": "git.configure", "options": {} },
    {
      "id": "firewall.devPorts",
      "options": { "ports": [3000, 3001, 4200, 5000, 8000, 8080, 8081], "profile": "Private", "remoteAddress": "LocalSubnet" }
    },
    {
      "id": "defender.exclusions",
      "options": { "paths": ["%USERPROFILE%\\\\Documents\\\\GitHub", "%USERPROFILE%\\\\Documents\\\\Projects", "%USERPROFILE%\\\\.nuget"] }
    }
  ],
  "services": {
    "database": { "mode": "Container", "composeFile": "compose/db.compose.yaml" },
    "web": { "mode": "Container", "composeFile": "compose/web.compose.yaml" },
    "homeAssistant": { "mode": "Skip", "composeFile": "compose/ha.compose.yaml" }
  }
}
